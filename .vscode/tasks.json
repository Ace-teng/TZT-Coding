{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C/C++: g++.exe 生成活动文件",  // 必须与launch.json的preLaunchTask完全一致
            "type": "cppbuild",
            "command": "C:/mingw64/bin/g++.exe",  // 确认此路径是否存在g++.exe
            "args": [
                "-fdiagnostics-color=always",
                "-g",  // 生成调试信息（必须保留，否则无法调试）
                "${file}",  // 当前激活的.cpp文件（如a.cpp）
                "-o",  // 输出可执行文件
                "${fileDirname}\\${fileBasenameNoExtension}.exe"  // 输出路径：与launch.json的program对应
            ],
            "options": {
                "cwd": "${fileDirname}"  // 工作目录：源代码所在目录（正确设置）
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true  // 设置为默认编译任务（按Ctrl+Shift+B可直接执行）
            },
            "detail": "编译器: C:/mingw64/bin/g++.exe"
        }
    ]
}